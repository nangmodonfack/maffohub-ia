{
  "rewrites": [
    {
      "source": "/support",
      "destination": "/ia/support/index.html"
    },
    {
      "source": "/gpt-4o",
      "destination": "/ia/gpt-4o/index.html"
    },
    {
      "source": "/o1",
      "destination": "/ia/o1/index.html"
    },
    {
      "source": "/chatgpt5",
      "destination": "/ia/chatgpt5/index.html"
    },
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "ia.maffohub.com" }
      ],
      "destination": "/ia/index.html"
    },
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "app.maffohub.com" }
      ],
      "destination": "/app/index.html"
    }
  ]
}
